<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="website.header_text_element" model="ir.ui.view">
        <field name="arch" type="xml">
            <t/>
        </field>
    </record>

    <template id="iz_layout_favicon" inherit_id="website.layout" name="Iron Zone Favicon">
        <xpath expr="//link[@rel='shortcut icon']" position="replace">
            <link rel="shortcut icon" type="image/png" href="/iz_website/static/src/img/iz-badge.png"/>
        </xpath>
        <xpath expr="//head" position="inside">
            <link rel="icon" type="image/png" href="/iz_website/static/src/img/iz-badge.png"/>
            <link rel="apple-touch-icon" href="/iz_website/static/src/img/iz-badge.png"/>
        </xpath>
    </template>
</odoo>
