<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="iz_shop_page" inherit_id="website_sale.products" name="Iron Zone Shop">
        <xpath expr="//div[@id='wrap']" position="attributes">
            <attribute name="class" add="iz-shop-page" separator=" "/>
        </xpath>
        <xpath expr="//div[hasclass('container', 'oe_website_sale')]" position="before">
            <section class="iz-shop_header">
                <div class="container">
                    <p class="iz-eyebrow">Tienda</p>
                    <h1>Planes, clases y productos.</h1>
                </div>
            </section>
        </xpath>
        <xpath expr="//div[hasclass('products_header')]" position="attributes">
            <attribute name="class" add="iz-products_header" separator=" "/>
        </xpath>
        <xpath expr="//section[@id='o_wsale_products_grid']" position="attributes">
            <attribute name="class" add="iz-products_grid" separator=" "/>
        </xpath>
    </template>

    <template id="iz_shop_card" inherit_id="website_sale.products_item" name="Iron Zone Product Card">
        <xpath expr="//form[hasclass('oe_product_cart')]" position="attributes">
            <attribute name="class" add="iz-product_card" separator=" "/>
        </xpath>
        <xpath expr="//div[hasclass('o_wsale_product_information')]" position="attributes">
            <attribute name="class" add="iz-product_info" separator=" "/>
        </xpath>
        <xpath expr="//h6[hasclass('o_wsale_products_item_title')]" position="after">
            <p class="iz-product_note" t-if="product.public_categ_ids">
                <t t-esc="product.public_categ_ids[0].name"/>
            </p>
        </xpath>
    </template>

    <template id="iz_product_page" inherit_id="website_sale.product" name="Iron Zone Product Detail">
        <xpath expr="//section[@id='product_detail']" position="attributes">
            <attribute name="class" add="iz-product_detail" separator=" "/>
        </xpath>
        <xpath expr="//div[@id='product_details']/h1" position="before">
            <p class="iz-eyebrow" t-if="product.public_categ_ids">
                <t t-esc="product.public_categ_ids[0].name"/>
            </p>
        </xpath>
        <xpath expr="//div[@t-field='product.description_ecommerce']" position="replace">
            <div class="iz-product_description">
                <div t-if="product.description_ecommerce" t-field="product.description_ecommerce" class="oe_structure"/>
                <p t-elif="product.description_sale" t-field="product.description_sale"/>
            </div>
        </xpath>
        <xpath expr="//div[@id='o_product_terms_and_share']" position="attributes">
            <attribute name="class">iz-product_terms_share</attribute>
        </xpath>
    </template>

    <template id="iz_payment_page" inherit_id="website_sale.payment" name="Iron Zone Payment Page">
        <xpath expr="//div[@id='o_wsale_total_accordion_item']" position="attributes">
            <attribute name="style">background: var(--iz-surface) !important; border: 1px solid var(--iz-line) !important; color: var(--iz-text) !important; border-radius: 18px;</attribute>
        </xpath>
        <xpath expr="//div[@id='o_wsale_total_accordion_item']/div[contains(@class, 'accordion-header')]/button[contains(@class, 'accordion-button')]" position="attributes">
            <attribute name="style">background: var(--iz-surface) !important; color: var(--iz-text) !important; box-shadow: none !important; padding-left: 0 !important; padding-right: 0 !important;</attribute>
        </xpath>
        <xpath expr="//div[@id='cart_total']" position="attributes">
            <attribute name="style">background: var(--iz-surface) !important; color: var(--iz-text) !important; border-top: 1px solid var(--iz-line) !important;</attribute>
        </xpath>
        <xpath expr="//div[@id='o_wsale_total_accordion_item']//table[@id='cart_products']" position="attributes">
            <attribute name="style">background: var(--iz-surface) !important; color: var(--iz-text) !important;</attribute>
        </xpath>
        <xpath expr="//div[@id='o_wsale_total_accordion_item']//div[contains(@class, 'coupon_form')]" position="attributes">
            <attribute name="style">background: var(--iz-surface) !important; color: var(--iz-text) !important;</attribute>
        </xpath>
        <xpath expr="//div[@id='o_wsale_total_accordion_item']//div[contains(@class, 'input-group')]" position="attributes">
            <attribute name="style">background: var(--iz-surface) !important; border-color: var(--iz-line) !important;</attribute>
        </xpath>
        <xpath expr="//div[@id='o_wsale_total_accordion_item']//div[contains(@class, 'input-group')]//input" position="attributes">
            <attribute name="style">background: var(--iz-surface-2) !important; border-color: var(--iz-line) !important; color: var(--iz-text) !important;</attribute>
        </xpath>
        <xpath expr="//div[@id='o_wsale_total_accordion_item']//div[contains(@class, 'input-group')]//a[contains(@class, 'btn')]" position="attributes">
            <attribute name="style">background: linear-gradient(135deg, #ff6a42, #ff4f86) !important; border: 0 !important; color: #fff !important;</attribute>
        </xpath>
        <xpath expr="//div[@id='o_wsale_total_accordion_item']//button[@name='o_payment_submit_button']" position="attributes">
            <attribute name="style">background: linear-gradient(135deg, #ff6a42, #ff4f86) !important; border: 0 !important; color: #fff !important; box-shadow: 0 12px 26px rgba(255, 90, 47, 0.28) !important;</attribute>
        </xpath>
        <xpath expr="//div[@id='o_wsale_total_accordion_item']//a[@href='/shop/checkout']" position="attributes">
            <attribute name="style">color: var(--iz-muted) !important;</attribute>
        </xpath>
        <xpath expr="//h4[@id='o_payment_tokens_heading']" position="attributes">
            <attribute name="style">color: #fff !important;</attribute>
        </xpath>
        <xpath expr="//li[@name='o_payment_option']" position="attributes">
            <attribute name="style">background: var(--iz-surface) !important; border: 1px solid var(--iz-line) !important; color: var(--iz-text) !important; border-radius: 16px; margin-bottom: 1rem;</attribute>
        </xpath>
    </template>
</odoo>
