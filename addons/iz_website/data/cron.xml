<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data noupdate="1">

    <!-- ── Cumpleaños (diario) ── -->
    <record id="ir_cron_send_birthdays" model="ir.cron">
      <field name="name">IZ: Enviar emails de cumpleaños</field>
      <field name="model_id" ref="base.model_res_partner"/>
      <field name="state">code</field>
      <field name="code">model.env['iz.marketing'].send_birthday_emails()</field>
      <field name="interval_number">1</field>
      <field name="interval_type">days</field>
      <field name="active">True</field>
    </record>

    <!-- ── Campañas de segmentación (diario) ── -->
    <record id="ir_cron_send_campaigns" model="ir.cron">
      <field name="name">IZ: Enviar campañas de marketing</field>
      <field name="model_id" ref="base.model_res_partner"/>
      <field name="state">code</field>
      <field name="code">model.env['iz.marketing'].send_marketing_campaigns()</field>
      <field name="interval_number">1</field>
      <field name="interval_type">days</field>
      <field name="active">True</field>
    </record>

    <!-- ── Membresías próximas a vencer (diario) ── -->
    <record id="ir_cron_membership_expiry" model="ir.cron">
      <field name="name">IZ: Membresías por vencer (7 días)</field>
      <field name="model_id" ref="base.model_res_partner"/>
      <field name="state">code</field>
      <field name="code">model.env['iz.marketing'].send_membership_expiry_campaign()</field>
      <field name="interval_number">1</field>
      <field name="interval_type">days</field>
      <field name="active">True</field>
    </record>

    <!-- ── Día de la Mujer – 8 de marzo (diario, lógica interna filtra) ── -->
    <record id="ir_cron_womens_day" model="ir.cron">
      <field name="name">IZ: Campaña Día de la Mujer</field>
      <field name="model_id" ref="base.model_res_partner"/>
      <field name="state">code</field>
      <field name="code">model.env['iz.marketing'].send_womens_day_campaign()</field>
      <field name="interval_number">1</field>
      <field name="interval_type">days</field>
      <field name="active">True</field>
    </record>

    <!-- ── Día del Hombre – 19 de noviembre (diario, lógica interna filtra) ── -->
    <record id="ir_cron_mens_day" model="ir.cron">
      <field name="name">IZ: Campaña Día del Hombre</field>
      <field name="model_id" ref="base.model_res_partner"/>
      <field name="state">code</field>
      <field name="code">model.env['iz.marketing'].send_mens_day_campaign()</field>
      <field name="interval_number">1</field>
      <field name="interval_type">days</field>
      <field name="active">True</field>
    </record>

    <!-- ── Campañas estacionales (diario, lógica interna filtra) ── -->
    <record id="ir_cron_seasonal" model="ir.cron">
      <field name="name">IZ: Campañas estacionales (Navidad, Día Madre, Día Padre)</field>
      <field name="model_id" ref="base.model_res_partner"/>
      <field name="state">code</field>
      <field name="code">model.env['iz.marketing'].send_seasonal_campaigns()</field>
      <field name="interval_number">1</field>
      <field name="interval_type">days</field>
      <field name="active">True</field>
    </record>

  </data>
</odoo>
