<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- View: List -->
    <record id="view_iz_tasks_task_list" model="ir.ui.view">
        <field name="name">iz_tasks.task.list</field>
        <field name="model">iz_tasks.task</field>
        <field name="arch" type="xml">
            <list decoration-danger="date_deadline &lt; current_date and state != 'finalizada'" decoration-muted="state == 'finalizada'">
                <field name="name"/>
                <field name="user_id" widget="many2one_avatar"/>
                <field name="date_deadline"/>
                <field name="priority" widget="badge" decoration-danger="priority == 'alta'" decoration-warning="priority == 'media'" decoration-info="priority == 'baja'"/>
                <field name="state" widget="badge" decoration-success="state == 'finalizada'" decoration-info="state == 'en_proceso'" decoration-muted="state == 'creada'"/>
            </list>
        </field>
    </record>

    <!-- View: Form -->
    <record id="view_iz_tasks_task_form" model="ir.ui.view">
        <field name="name">iz_tasks.task.form</field>
        <field name="model">iz_tasks.task</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="state" widget="statusbar" options="{'clickable': '1'}"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Título de la tarea..."/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="user_id" widget="many2one_avatar"/>
                            <field name="priority" widget="priority"/>
                        </group>
                        <group>
                            <field name="date_deadline"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Descripción">
                            <field name="description"/>
                        </page>
                    </notebook>
                </sheet>
                <!-- Chatter for messages and activities -->
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="activity_ids" widget="mail_activity"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>

    <!-- View: Kanban -->
    <record id="view_iz_tasks_task_kanban" model="ir.ui.view">
        <field name="name">iz_tasks.task.kanban</field>
        <field name="model">iz_tasks.task</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column" records_draggable="1">
                <field name="name"/>
                <field name="user_id"/>
                <field name="state"/>
                <field name="priority"/>
                <field name="date_deadline"/>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_global_click oe_semantic_html_override">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title"><field name="name"/></strong>
                                </div>
                            </div>
                            <div class="o_kanban_record_body">
                                <div>
                                    <field name="priority" widget="priority"/>
                                </div>
                                <div t-if="record.date_deadline.raw_value" class="text-muted">
                                    <i class="fa fa-clock-o" aria-label="Fecha Límite" role="img" title="Fecha Límite"/> <field name="date_deadline"/>
                                </div>
                            </div>
                            <div class="o_kanban_record_bottom mt-2">
                                <div class="oe_kanban_bottom_left">
                                </div>
                                <div class="oe_kanban_bottom_right">
                                    <field name="user_id" widget="many2one_avatar_user"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- View: Graph (For Dashboard) -->
    <record id="view_iz_tasks_task_graph" model="ir.ui.view">
        <field name="name">iz_tasks.task.graph</field>
        <field name="model">iz_tasks.task</field>
        <field name="arch" type="xml">
            <graph string="Análisis de Tareas" type="bar">
                <field name="state"/>
                <field name="priority"/>
            </graph>
        </field>
    </record>

    <!-- View: Pivot (For Dashboard) -->
    <record id="view_iz_tasks_task_pivot" model="ir.ui.view">
        <field name="name">iz_tasks.task.pivot</field>
        <field name="model">iz_tasks.task</field>
        <field name="arch" type="xml">
            <pivot string="Análisis de Tareas">
                <field name="user_id" type="row"/>
                <field name="state" type="col"/>
            </pivot>
        </field>
    </record>

    <!-- View: Search (Filters and Group By) -->
    <record id="view_iz_tasks_task_search" model="ir.ui.view">
        <field name="name">iz_tasks.task.search</field>
        <field name="model">iz_tasks.task</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" string="Tarea"/>
                <field name="user_id"/>
                
                <filter string="Mis Tareas" name="my_tasks" domain="[('user_id', '=', uid)]"/>
                <separator/>
                <filter string="Próximas a Vencer" name="due_soon" domain="[('date_deadline', '&lt;=', (context_today() + datetime.timedelta(days=7)).strftime('%Y-%m-%d')), ('state', '!=', 'finalizada')]"/>
                <filter string="Atrasadas" name="overdue" domain="[('date_deadline', '&lt;', context_today().strftime('%Y-%m-%d')), ('state', '!=', 'finalizada')]"/>
                
                <group expand="0" string="Agrupar Por">
                    <filter string="Responsable" name="group_by_user" context="{'group_by': 'user_id'}"/>
                    <filter string="Estado" name="group_by_state" context="{'group_by': 'state'}"/>
                    <filter string="Prioridad" name="group_by_priority" context="{'group_by': 'priority'}"/>
                </group>
            </search>
        </field>
    </record>

</odoo>
