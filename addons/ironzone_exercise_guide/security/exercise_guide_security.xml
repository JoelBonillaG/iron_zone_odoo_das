<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="rule_exercise_guide_public_published" model="ir.rule">
        <field name="name">Guias publicadas visibles para visitantes</field>
        <field name="model_id" ref="model_ironzone_exercise_guide"/>
        <field name="groups" eval="[(4, ref('base.group_public'))]"/>
        <field name="domain_force">[('is_published', '=', True), ('state', '=', 'published'), ('active', '=', True), ('requires_subscription', '=', False)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="rule_exercise_guide_portal_published" model="ir.rule">
        <field name="name">Portal lee guias publicadas</field>
        <field name="model_id" ref="model_ironzone_exercise_guide"/>
        <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
        <field name="domain_force">[('is_published', '=', True), ('state', '=', 'published'), ('active', '=', True)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="rule_exercise_guide_internal_read" model="ir.rule">
        <field name="name">Usuarios internos sin rol no leen guias</field>
        <field name="model_id" ref="model_ironzone_exercise_guide"/>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        <field name="domain_force">[('id', '=', 0)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="rule_exercise_guide_trainer_own_write" model="ir.rule">
        <field name="name">Entrenadores editan sus propias guias</field>
        <field name="model_id" ref="model_ironzone_exercise_guide"/>
        <field name="groups" eval="[(4, ref('iz_backend_theme.group_ironzone_trainers'))]"/>
        <field name="domain_force">[('author_user_id', '=', user.id)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <record id="rule_exercise_guide_trainer_create" model="ir.rule">
        <field name="name">Entrenadores crean guias</field>
        <field name="model_id" ref="model_ironzone_exercise_guide"/>
        <field name="groups" eval="[(4, ref('iz_backend_theme.group_ironzone_trainers'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="perm_read" eval="False"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="rule_exercise_guide_admin_all" model="ir.rule">
        <field name="name">Administradores gestionan todas las guias</field>
        <field name="model_id" ref="model_ironzone_exercise_guide"/>
        <field name="groups" eval="[(4, ref('iz_backend_theme.group_ironzone_admin'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <record id="rule_gym_machine_public_read" model="ir.rule">
        <field name="name">Visitantes leen solo maquinas del gimnasio</field>
        <field name="model_id" ref="maintenance.model_maintenance_equipment"/>
        <field name="groups" eval="[(4, ref('base.group_public')), (4, ref('base.group_portal'))]"/>
        <field name="domain_force">[('is_gym_machine', '=', True), ('active', '=', True)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>
</odoo>
