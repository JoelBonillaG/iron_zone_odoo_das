<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_partner_form_l10n_ec" model="ir.ui.view">
        <field name="name">res.partner.form.l10n.ec</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="l10n_latam_base.view_partner_latam_form"/>
        <field name="priority">110</field>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='vat_vies_container']" position="after">
                <field name="l10n_ec_identifier_type" invisible="1"/>
                <field name="l10n_ec_taxpayer_type" invisible="1"/>
                <field name="l10n_ec_contributor_type_id"
                       string="SRI Tipo de Contribuyente"
                       invisible="country_id != %(base.ec)d"
                       options="{'no_create_edit': False}"/>
                <field name="l10n_ec_related_party"
                       string="Related Party"
                       invisible="country_id != %(base.ec)d"/>
            </xpath>
        </field>
    </record>
</odoo>
