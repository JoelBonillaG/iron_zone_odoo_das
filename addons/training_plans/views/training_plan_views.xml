<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Acción para ver registros de mis eventos -->
    <record id="action_event_registration_from_event" model="ir.actions.act_window">
        <field name="name">Registros de mis eventos</field>
        <field name="res_model">event.registration</field>
        <field name="view_mode">list,form</field>
        <field name="context">{}</field>
        <field name="domain">[("event_id.user_id", "=", uid)]</field>
    </record>
    <!-- Vista de lista para eventos del empleado actual -->
    <record id="view_event_employee_list" model="ir.ui.view">
        <field name="name">Mis Eventos - Lista</field>
        <field name="model">event.event</field>
        <field name="arch" type="xml">
            <list string="Eventos">
                <field name="name"/>
                <field name="date_begin" widget="date"/>
                <field name="date_end" widget="date"/>
                <field name="seats_available"/>
                <field name="seats_max"/>
                <field name="stage_id"/>
            </list>
        </field>
    </record>

    <!-- Vista de formulario para eventos del empleado actual -->
    <record id="view_event_employee_form" model="ir.ui.view">
        <field name="name">Mis Eventos - Detalle</field>
        <field name="model">event.event</field>
        <field name="arch" type="xml">
            <form string="Evento">
                <header>
                    <field name="stage_id" widget="statusbar" options="{'clickable': True}"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="%(action_event_registration_from_event)d" type="action" class="oe_stat_button" icon="fa-list">
                            <field name="seats_available" widget="statinfo" string="Registros"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Nombre del evento"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="date_begin" widget="datetime"/>
                            <field name="date_end" widget="datetime"/>
                        </group>
                        <group>
                            <field name="seats_max"/>
                            <field name="seats_available"/>
                        </group>
                    </group>
                    <group>
                        <group>
                            <field name="user_id" readonly="1"/>
                            <field name="stage_id"/>
                        </group>
                        <group>
                            <field name="company_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Descripción">
                            <field name="description" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Vista kanban para eventos del empleado actual -->
    <record id="view_event_employee_kanban" model="ir.ui.view">
        <field name="name">Mis Eventos - Kanban</field>
        <field name="model">event.event</field>
        <field name="arch" type="xml">
            <kanban default_group_by="stage_id" quick_create="False">
                <field name="id"/>
                <field name="name"/>
                <field name="date_begin"/>
                <field name="date_end"/>
                <field name="seats_available"/>
                <field name="seats_max"/>
                <field name="stage_id"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_card oe_kanban_global_click">
                            <div class="oe_kanban_content">
                                <h4>
                                    <field name="name"/>
                                </h4>
                                <p>
                                    <strong>Fecha:</strong>
                                    <field name="date_begin" widget="date"/>
                                </p>
                                <p>
                                    <strong>Registros:</strong>
                                    <field name="seats_available"/>
                                    /
                                    <field name="seats_max"/>
                                </p>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Vista calendario para eventos del empleado actual -->
    <record id="view_event_employee_calendar" model="ir.ui.view">
        <field name="name">Mis Eventos - Calendario</field>
        <field name="model">event.event</field>
        <field name="arch" type="xml">
            <calendar string="Eventos" date_start="date_begin" date_stop="date_end" color="stage_id">
                <field name="name"/>
                <field name="stage_id"/>
                <field name="seats_available"/>
            </calendar>
        </field>
    </record>

    <!-- Acción para vista de Mis Eventos (solo eventos del usuario actual) -->
    <record id="action_event_employee_view" model="ir.actions.act_window">
        <field name="name">Mis Eventos</field>
        <field name="res_model">event.event</field>
        <field name="type">ir.actions.act_window</field>
        <field name="view_mode">kanban,list,form,calendar</field>
        <field name="domain">[("user_id", "=", uid)]</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Aquí puedes ver y gestionar tus eventos asignados.
            </p>
        </field>
    </record>

    <!-- Menú para Mis Eventos en el backend -->
    <menuitem
        id="menu_event_employee"
        name="Mis Eventos"
        parent="hr.menu_hr_root"
        action="action_event_employee_view"
        sequence="10"/>

    <!-- Regla de seguridad: empleados solo ven sus propios eventos -->
    <record id="ir_rule_event_employee_own" model="ir.rule">
        <field name="name">Empleado ve solo sus eventos</field>
        <field name="model_id" ref="event.model_event_event"/>
        <field name="groups" eval="[(4, ref('hr.group_hr_user'))]"/>
        <field name="domain_force">[("user_id", "=", user.id)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="ir_rule_event_admin_all" model="ir.rule">
        <field name="name">Administrador ve todos los eventos</field>
        <field name="model_id" ref="event.model_event_event"/>
        <field name="groups" eval="[(4, ref('base.group_system'))]"/>
        <field name="domain_force">[(1, "=", 1)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <!-- Acceso a registro de eventos para empleados -->
    <record id="view_event_registration_employee_form" model="ir.ui.view">
        <field name="name">Registro a Evento - Detalle</field>
        <field name="model">event.registration</field>
        <field name="arch" type="xml">
            <form string="Registro">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="email"/>
                            <field name="phone"/>
                        </group>
                        <group>
                            <field name="event_id" readonly="1"/>
                            <field name="state"/>
                            <field name="create_date"/>
                            <field name="date_closed"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_event_registration_employee_list" model="ir.ui.view">
        <field name="name">Registros a Eventos - Lista</field>
        <field name="model">event.registration</field>
        <field name="arch" type="xml">
            <list string="Registros">
                <field name="name"/>
                <field name="email"/>
                <field name="event_id"/>
                <field name="state"/>
                <field name="create_date" widget="date"/>
            </list>
        </field>
    </record>


</odoo>
