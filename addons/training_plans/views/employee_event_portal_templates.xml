<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="menu_employee_events" model="website.menu">
        <field name="name">Mis eventos</field>
        <field name="url">/my/events</field>
        <field name="parent_id" ref="website.main_menu"/>
        <field name="group_ids" eval="[(3, ref('website.group_website_designer')), (4, ref('group_training_instructor_portal'))]"/>
        <field name="sequence" type="int">70</field>
    </record>

    <template id="employee_events_page" name="Mis eventos del empleado">
        <t t-call="website.layout">
            <div id="wrap" class="iz-site iz-employee-events">
                <style>
                    .iz-employee-events {
                        background:
                            radial-gradient(circle at top left, rgba(255, 87, 34, 0.14), transparent 32rem),
                            linear-gradient(180deg, #101827 0%, #080b10 58%, #06080c 100%);
                        color: #f8fafc;
                        min-height: 72vh;
                    }
                    .iz-employee-events .iz-events-header {
                        background: transparent;
                        color: #fff;
                        padding: 58px 0 28px;
                    }
                    .iz-employee-events .iz-events-header h1 {
                        font-size: clamp(42px, 5vw, 64px);
                        line-height: 1;
                        margin: 0;
                        letter-spacing: 0;
                    }
                    .iz-employee-events .iz-events-header p {
                        color: #cbd5e1;
                        font-size: 18px;
                        margin: 14px 0 0;
                    }
                    .iz-employee-events .iz-events-body {
                        padding: 28px 0 64px;
                    }
                    .iz-employee-events .iz-events-grid {
                        display: grid;
                        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
                        gap: 18px;
                    }
                    .iz-employee-events .iz-event-card {
                        position: relative;
                        overflow: hidden;
                        background: linear-gradient(180deg, rgba(31, 41, 55, 0.92), rgba(15, 23, 42, 0.92));
                        border: 1px solid rgba(148, 163, 184, 0.22);
                        border-radius: 8px;
                        padding: 20px;
                        box-shadow: 0 18px 40px rgba(0, 0, 0, 0.28);
                        transition: transform 160ms ease, border-color 160ms ease, box-shadow 160ms ease;
                    }
                    .iz-employee-events .iz-event-card::before {
                        content: "";
                        position: absolute;
                        inset: 0 0 auto;
                        height: 3px;
                        background: linear-gradient(90deg, #ff5a2f, #f7b733);
                    }
                    .iz-employee-events .iz-event-card:hover {
                        transform: translateY(-2px);
                        border-color: rgba(255, 90, 47, 0.58);
                        box-shadow: 0 24px 48px rgba(0, 0, 0, 0.36);
                    }
                    .iz-employee-events .iz-event-card h3 {
                        color: #fff;
                        font-size: 19px;
                        line-height: 1.25;
                        margin: 0 0 16px;
                    }
                    .iz-employee-events .iz-event-meta {
                        display: grid;
                        gap: 0;
                        margin: 0;
                    }
                    .iz-employee-events .iz-event-meta div {
                        display: flex;
                        justify-content: space-between;
                        gap: 12px;
                        border-top: 1px solid rgba(148, 163, 184, 0.18);
                        padding: 10px 0;
                    }
                    .iz-employee-events .iz-event-meta dt {
                        color: #a9b8cf;
                        font-weight: 600;
                    }
                    .iz-employee-events .iz-event-meta dd {
                        color: #f8fafc;
                        font-weight: 600;
                        margin: 0;
                        text-align: right;
                    }
                    .iz-employee-events .iz-empty {
                        background: rgba(15, 23, 42, 0.9);
                        border: 1px solid rgba(148, 163, 184, 0.22);
                        border-radius: 8px;
                        padding: 24px;
                    }
                    .iz-employee-events .iz-empty h2 {
                        color: #fff;
                    }
                    .iz-employee-events .iz-empty p {
                        color: #cbd5e1;
                    }
                    @media (max-width: 767px) {
                        .iz-employee-events .iz-events-header {
                            padding-top: 40px;
                        }
                        .iz-employee-events .iz-events-grid {
                            grid-template-columns: 1fr;
                        }
                    }
                </style>

                <section class="iz-events-header">
                    <div class="container">
                        <h1>Mis eventos</h1>
                        <p>Eventos asignados a tu usuario de empleado.</p>
                    </div>
                </section>

                <section class="iz-events-body">
                    <div class="container">
                        <div t-if="events" class="iz-events-grid">
                            <article t-foreach="events" t-as="event" class="iz-event-card">
                                <h3 t-field="event.name"/>
                                <dl class="iz-event-meta">
                                    <div>
                                        <dt>Inicio</dt>
                                        <dd>
                                            <span t-field="event.date_begin"/>
                                        </dd>
                                    </div>
                                    <div>
                                        <dt>Fin</dt>
                                        <dd>
                                            <span t-field="event.date_end"/>
                                        </dd>
                                    </div>
                                    <div>
                                        <dt>Etapa</dt>
                                        <dd>
                                            <span t-field="event.stage_id.name"/>
                                        </dd>
                                    </div>
                                    <div>
                                        <dt>Registros</dt>
                                        <dd>
                                            <t t-esc="registration_counts.get(event.id, 0)"/>
                                            <t t-if="event.seats_max"> / <span t-field="event.seats_max"/></t>
                                        </dd>
                                    </div>
                                </dl>
                            </article>
                        </div>
                        <div t-else="" class="iz-empty">
                            <h2>No tienes eventos asignados</h2>
                            <p>Cuando un administrador te asigne una clase, aparecerá aquí.</p>
                        </div>
                    </div>
                </section>
            </div>
        </t>
    </template>

    <template id="employee_events_portal_home_card" inherit_id="portal.portal_my_home" name="Employee Events Portal Home Card">
        <xpath expr="//div[@id='portal_common_category']" position="inside">
            <t t-if="request.env.user.has_group('training_plans.group_training_instructor_portal')" t-call="portal.portal_docs_entry">
                <t t-set="icon" t-value="'/event/static/src/img/event.svg'"/>
                <t t-set="title">Mis eventos</t>
                <t t-set="text">Consulta tus clases asignadas</t>
                <t t-set="url" t-value="'/my/events'"/>
            </t>
        </xpath>
    </template>
</odoo>
