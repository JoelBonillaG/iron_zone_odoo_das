<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_subscription_stage_form" model="ir.ui.view">
        <field name="name">view.subscription.stage.form</field>
        <field name="model">sale.subscription.stage</field>
        <field name="arch" type="xml">
            <form string="Etapa de suscripcion">
                <sheet>
                    <group name="main">
                        <group>
                            <field name="name" />
                            <field name="in_progress" invisible="True" />
                            <field
                                name="sequence"
                                help="
                Este campo dicta el orden visual de las etapas en las vistas Kanban y de formulario. Aunque es puramente visual, ten en cuenta que si el orden no es
                consecuente con tus necesidades, podrías tener una etapa de tipo 'Cerrada' antes de una de tipo 'Lista para empezar'.
                "
                            />
                            <field
                                name="type"
                                help="Las etapas definen el ciclo de vida de una suscripción dada; esto es,
                una suscripción puede estar en una etapa de tipo 'Lista para empezar', 'En progreso' o 'Cerrada'.
                Ten en cuenta que solo puede haber una etapa de tipo 'Cerrada'."
                            />
                            <field name="fold" />
                        </group>
                    </group>
                    <field
                        name="description"
                        placeholder="Add new description..."
                        nolabel="1"
                    />
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_subscription_stage_tree" model="ir.ui.view">
        <field name="name">view.subscription.stage.list</field>
        <field name="model">sale.subscription.stage</field>
        <field name="arch" type="xml">
            <list>
                <field name="name" />
            </list>
        </field>
    </record>

    <record id="subscription_stage_action" model="ir.actions.act_window">
        <field name="name">Etapas de suscripcion</field>
        <field name="res_model">sale.subscription.stage</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                Crea una nueva etapa de suscripcion.
            </p>
        </field>
    </record>

    <menuitem
        id="subscription_stage_menu"
        parent="sale_subscription_configuration_menu"
        action="subscription_stage_action"
        sequence="20"
        name="Etapas de suscripcion"
    />
</odoo>
