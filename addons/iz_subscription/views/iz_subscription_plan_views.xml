<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="iz_membership_plan_list" model="ir.ui.view">
        <field name="name">iz.subscription.plan.list</field>
        <field name="model">iz.subscription.plan</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle" />
                <field name="name" />
                <field name="code" />
                <field name="priority" />
                <field name="active" string="Activo" />
            </list>
        </field>
    </record>

    <record id="iz_membership_plan_form" model="ir.ui.view">
        <field name="name">iz.subscription.plan.form</field>
        <field name="model">iz.subscription.plan</field>
        <field name="arch" type="xml">
            <form string="Plan de suscripcion">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Ej. IronZone Basico" />
                        </h1>
                    </div>
                    <group>
                        <group string="Identificacion">
                            <field name="code" string="Codigo interno" />
                            <field name="priority" string="Prioridad de beneficios" />
                            <field name="active" string="Activo" />
                        </group>
                        <group string="Detalle">
                            <field name="description" string="Descripcion" />
                        </group>
                    </group>
                    <notebook>
                        <page string="Beneficios que otorga">
                            <field name="benefit_ids" context="{'default_plan_id': id}">
                                <list>
                                    <field name="sequence" widget="handle" />
                                    <field name="name" />
                                    <field name="benefit_scope" string="Modulo" />
                                    <field name="benefit_type" string="Beneficio" />
                                    <field name="discount_percent" string="Descuento (%)" />
                                    <field name="active" string="Activo" />
                                </list>
                            </field>
                        </page>
                        <page string="Productos que dan este plan">
                            <field name="product_template_ids" readonly="1">
                                <list>
                                    <field name="name" />
                                    <field name="list_price" string="Precio" />
                                    <field name="subscription_template_id" string="Plantilla de recurrencia" />
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="iz_membership_benefit_list" model="ir.ui.view">
        <field name="name">iz.subscription.benefit.list</field>
        <field name="model">iz.subscription.benefit</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle" />
                <field name="name" />
                <field name="plan_id" string="Plan" />
                <field name="benefit_scope" string="Modulo" />
                <field name="benefit_type" string="Beneficio" />
                <field name="discount_percent" string="Descuento (%)" />
                <field name="active" string="Activo" />
            </list>
        </field>
    </record>

    <record id="iz_membership_benefit_form" model="ir.ui.view">
        <field name="name">iz.subscription.benefit.form</field>
        <field name="model">iz.subscription.benefit</field>
        <field name="arch" type="xml">
            <form string="Beneficio de suscripcion">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Ej. 20% en clases" />
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="plan_id" string="Plan" />
                            <field name="benefit_scope" string="Modulo donde aplica" />
                            <field name="benefit_type" string="Beneficio" />
                            <field name="discount_percent" string="Descuento (%)" />
                            <field name="active" string="Activo" />
                        </group>
                        <group>
                            <field name="description" string="Descripcion" />
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="iz_membership_plan_action" model="ir.actions.act_window">
        <field name="name">Planes</field>
        <field name="res_model">iz.subscription.plan</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="iz_membership_benefit_action" model="ir.actions.act_window">
        <field name="name">Beneficios</field>
        <field name="res_model">iz.subscription.benefit</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
        id="iz_membership_plan_menu"
        parent="sale_subscription_configuration_menu"
        action="iz_membership_plan_action"
        name="Planes"
        sequence="5"
    />

    <menuitem
        id="iz_membership_benefit_menu"
        parent="sale_subscription_configuration_menu"
        action="iz_membership_benefit_action"
        sequence="6"
    />
</odoo>
