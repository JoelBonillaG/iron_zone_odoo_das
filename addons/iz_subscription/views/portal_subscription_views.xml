<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template
        id="portal_user_dropdown_subscriptions"
        inherit_id="portal.user_dropdown"
        name="Iron Zone User Dropdown Subscriptions"
        priority="84"
    >
        <xpath expr="//a[@id='o_backend_user_dropdown_link']" position="before">
            <a
                groups="base.group_portal"
                href="/my/subscriptions"
                role="menuitem"
                class="dropdown-item ps-3"
                id="o_my_subscriptions_dropdown_link"
            >
                <i class="fa fa-fw fa-repeat me-1 small text-primary text-primary-emphasis"/>
                Mis suscripciones
            </a>
        </xpath>
    </template>

    <template
        id="portal_my_home_subscription"
        inherit_id="portal.portal_my_home"
        name="Iron Zone Portal Subscriptions Card"
    >
        <xpath expr="//div[@id='portal_common_category']" position="before">
            <div id="portal_subscriptions_category" class="o_portal_category row g-2 mt-3">
                <h3 class="o_portal_category_title col-12">Suscripciones Iron Zone</h3>
                <div class="o_portal_index_card col-md-6 order-2">
                    <a
                        href="/my/subscriptions"
                        title="Mis suscripciones"
                        class="d-flex gap-2 gap-md-3 py-3 pe-2 px-md-3 h-100 rounded text-decoration-none bg-100"
                    >
                        <div class="o_portal_icon d-block align-self-start">
                            <img src="/iz_subscription/static/img/icon.png" loading="lazy" alt=""/>
                        </div>
                        <div>
                            <div class="mt-0 mb-1 fs-5 fw-normal lh-1">
                                <span>Mis suscripciones</span>
                            </div>
                            <div class="opacity-75">
                                Plan vigente, pagos y beneficios.
                            </div>
                        </div>
                    </a>
                </div>
            </div>
        </xpath>

        <xpath expr="//div[@id='portal_common_category']" position="inside">
            <h3 class="o_portal_category_title iz-account-settings-title col-12 order-0">
                Configuracion de cuenta
            </h3>
        </xpath>
    </template>

    <template id="portal_my_subscriptions" name="Mis suscripciones">
        <t t-call="website.layout">
            <div class="container py-5">
                <div class="iz-sub-wrap">
                    <p class="text-uppercase text-primary small fw-semibold mb-2">Iron Zone</p>
                    <h1 class="display-6 mb-4">Mis suscripciones</h1>

                    <t t-if="best_plan">
                        <div class="iz-sub-card rounded p-4 p-lg-5">
                            <div class="d-flex justify-content-between align-items-start gap-3 mb-1">
                                <div>
                                    <p class="iz-sub-eyebrow mb-1">Plan vigente</p>
                                    <h2 class="iz-sub-title mb-0"><t t-esc="best_plan.name"/></h2>
                                </div>
                                <span class="badge text-bg-success">Activa</span>
                            </div>
                            <p class="iz-sub-renew mb-4">
                                <t t-if="active_subscription.recurring_next_date">
                                    Se renueva automaticamente el
                                    <span t-field="active_subscription.recurring_next_date"/>
                                </t>
                                <t t-elif="active_subscription.date">
                                    Cancelada. Tus beneficios siguen activos hasta el
                                    <span t-field="active_subscription.date"/> y no se renovara.
                                </t>
                                <t t-else="">Suscripcion activa</t>
                            </p>

                            <div class="iz-sub-rows">
                                <div class="iz-sub-row">
                                    <span class="iz-sub-label">Suscripcion</span>
                                    <span class="iz-sub-value"><t t-esc="active_subscription.name"/></span>
                                </div>
                                <div class="iz-sub-row">
                                    <span class="iz-sub-label">
                                        <t t-if="active_subscription.recurring_next_date">Proxima facturacion</t>
                                        <t t-else="">Acceso hasta</t>
                                    </span>
                                    <span class="iz-sub-value">
                                        <t t-if="active_subscription.recurring_next_date">
                                            <span t-field="active_subscription.recurring_next_date"/>
                                        </t>
                                        <t t-elif="active_subscription.date">
                                            <span t-field="active_subscription.date"/>
                                        </t>
                                        <t t-else="">Sin fecha</t>
                                    </span>
                                </div>
                                <div class="iz-sub-row">
                                    <span class="iz-sub-label">Total recurrente</span>
                                    <span class="iz-sub-value">$<t t-esc="'%.2f' % active_subscription.amount_total"/></span>
                                </div>
                                <div class="iz-sub-row">
                                    <span class="iz-sub-label">Renovacion</span>
                                    <span class="iz-sub-value">
                                        <t t-if="active_subscription.recurring_next_date">Automatica</t>
                                        <t t-else="">Cancelada</t>
                                    </span>
                                </div>
                            </div>

                            <div class="accordion iz-sub-accordion mt-4" id="izBenefitsAccordion">
                                <div class="accordion-item">
                                    <h3 class="accordion-header" id="izBenefitsHeading">
                                        <button
                                            class="accordion-button collapsed"
                                            type="button"
                                            data-bs-toggle="collapse"
                                            data-bs-target="#izBenefitsBody"
                                            aria-expanded="false"
                                            aria-controls="izBenefitsBody"
                                        >
                                            Beneficios incluidos
                                            <span class="badge text-bg-light ms-2"><t t-esc="len(active_benefits)"/></span>
                                        </button>
                                    </h3>
                                    <div
                                        id="izBenefitsBody"
                                        class="accordion-collapse collapse"
                                        aria-labelledby="izBenefitsHeading"
                                        data-bs-parent="#izBenefitsAccordion"
                                    >
                                        <div class="accordion-body">
                                            <t t-if="active_benefits">
                                                <t t-foreach="active_benefits" t-as="benefit">
                                                    <div class="iz-sub-benefit d-flex gap-3 py-2">
                                                        <div class="text-primary">
                                                            <i t-att-class="'fa fa-lg ' + scope_icons.get(benefit.benefit_scope, 'fa-star')"/>
                                                        </div>
                                                        <div>
                                                            <div class="iz-sub-value fw-semibold"><t t-esc="benefit.name"/></div>
                                                            <div class="iz-sub-label small">
                                                                <t t-esc="scope_labels.get(benefit.benefit_scope, benefit.benefit_scope)"/>
                                                                <t t-if="benefit.benefit_type == 'discount'"> - <t t-esc="int(benefit.discount_percent)"/>% de descuento</t>
                                                                <t t-if="benefit.benefit_type == 'free'"> - incluido</t>
                                                            </div>
                                                            <div t-if="benefit.description" class="small mt-1"><t t-esc="benefit.description"/></div>
                                                        </div>
                                                    </div>
                                                </t>
                                            </t>
                                            <t t-else="">
                                                <p class="iz-sub-label mb-0">Este plan aun no tiene beneficios configurados.</p>
                                            </t>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="mt-4">
                                <a href="/shop" class="btn btn-outline-primary btn-sm">Ver planes</a>
                            </div>
                        </div>
                    </t>

                    <t t-if="billing_rows">
                        <div class="iz-sub-card rounded p-4 p-lg-5 mt-4">
                            <h2 class="iz-sub-section-title mb-1">Historial de facturacion</h2>
                            <p class="iz-sub-label small mb-4">Facturas de tus suscripciones Iron Zone.</p>
                            <div class="iz-bill-list">
                                <t t-foreach="billing_rows" t-as="row">
                                    <div class="iz-bill-row">
                                        <span class="iz-bill-date"><t t-esc="row['date']"/></span>
                                        <span class="iz-bill-amount"><t t-esc="row['currency']"/><t t-esc="'%.2f' % row['amount']"/></span>
                                        <span t-attf-class="badge #{'text-bg-success' if row['paid'] else 'text-bg-secondary'} iz-bill-badge">
                                            <t t-esc="row['status_label']"/>
                                        </span>
                                        <a t-att-href="row['url']" class="iz-bill-link" target="_blank">Ver factura</a>
                                    </div>
                                </t>
                            </div>
                        </div>
                    </t>

                    <t t-if="best_plan and active_subscription.recurring_next_date">
                        <div class="iz-sub-cancel mt-4 text-end">
                            <form
                                action="/my/subscriptions/cancel"
                                method="post"
                                onsubmit="return confirm('Se detendra la renovacion (no se te cobrara de nuevo). Tus beneficios siguen activos hasta el fin del periodo ya pagado. ¿Continuar?');"
                            >
                                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                <button type="submit" class="btn btn-link iz-cancel-link p-0">
                                    Cancelar suscripcion
                                </button>
                            </form>
                        </div>
                    </t>

                    <t t-if="not best_plan">
                        <div class="iz-sub-card rounded text-center py-5 px-4">
                            <i class="fa fa-repeat fa-2x text-primary mb-3"/>
                            <h2 class="h5">No tienes una suscripcion activa</h2>
                            <p class="iz-sub-label mb-3">
                                Compra un plan de Iron Zone para activar beneficios en clases y otros servicios.
                            </p>
                            <a href="/shop" class="btn btn-primary">Ver planes disponibles</a>
                        </div>
                    </t>
                </div>
            </div>
        </t>
    </template>
</odoo>
