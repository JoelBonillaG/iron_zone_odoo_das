<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Card in "Mi cuenta" portal home -->
    <template id="portal_my_home_subscription" inherit_id="portal.portal_my_home"
              name="Mis Suscripciones - Portal Card">
        <xpath expr="//div[@id='portal_common_category']" position="before">
            <div id="portal_subscriptions_category" class="o_portal_category mt-3">
                <h3 class="o_portal_category_title">Mis Suscripciones</h3>
                <t t-call="portal.portal_docs_entry">
                    <t t-set="icon" t-value="'/iz_subscription/static/img/icon.png'"/>
                    <t t-set="title">Mis Suscripciones y Beneficios</t>
                    <t t-set="text">Consulta tus suscripciones activas y los beneficios que tienes</t>
                    <t t-set="url" t-value="'/my/subscriptions'"/>
                    <t t-set="placeholder_count" t-value="'subscription_count'"/>
                </t>
            </div>
        </xpath>
    </template>

    <!-- Main subscriptions page template -->
    <template id="portal_my_subscriptions" name="Mis Suscripciones">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True"/>

            <t t-call="portal.portal_searchbar">
                <t t-set="title">Mis Suscripciones</t>
            </t>

            <div class="container-fluid px-0 py-3">

                <!-- ============================================================
                     BANNER: Plan activo y beneficios
                ============================================================ -->
                <t t-if="best_plan">
                    <div class="iz-plan-banner mb-4 p-4 rounded-3"
                         style="background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%); color: #fff; border: 1px solid rgba(255,107,0,0.3);">
                        <div class="row align-items-center">
                            <div class="col-md-8">
                                <div class="d-flex align-items-center gap-3 mb-2">
                                    <div class="iz-plan-badge"
                                         style="background: #ff6b00; border-radius: 50%; width: 48px; height: 48px; display:flex; align-items:center; justify-content:center;">
                                        <i class="fa fa-trophy fa-lg text-white"/>
                                    </div>
                                    <div>
                                        <p class="mb-0" style="font-size:0.8rem; color: rgba(255,255,255,0.6); text-transform:uppercase; letter-spacing:1px;">
                                            Plan activo
                                        </p>
                                        <h4 class="mb-0 fw-bold" style="color:#ff6b00;">
                                            <t t-esc="best_plan.name"/>
                                        </h4>
                                    </div>
                                </div>
                                <p class="mb-0" style="color:rgba(255,255,255,0.75); font-size:0.9rem;">
                                    Recibes los beneficios del plan de mayor nivel entre todas tus suscripciones activas.
                                    <!-- TODO: Restringir que si se tiene un plan mayor no se pueda comprar uno menor -->
                                </p>
                            </div>
                            <div class="col-md-4 text-md-end mt-3 mt-md-0">
                                <span class="badge px-3 py-2"
                                      style="background: rgba(255,107,0,0.2); color:#ff6b00; border: 1px solid rgba(255,107,0,0.4); font-size:0.9rem;">
                                    <i class="fa fa-check-circle me-1"/>
                                    Beneficios activos
                                </span>
                            </div>
                        </div>

                        <!-- Beneficios del plan activo -->
                        <t t-if="active_benefits">
                            <hr style="border-color: rgba(255,255,255,0.15); margin: 1.2rem 0;"/>
                            <h6 class="mb-3" style="color: rgba(255,255,255,0.8); text-transform:uppercase; letter-spacing:1px; font-size:0.75rem;">
                                <i class="fa fa-gift me-2" style="color:#ff6b00;"/>
                                Tus beneficios actuales
                            </h6>
                            <div class="row g-3">
                                <t t-foreach="active_benefits" t-as="benefit">
                                    <div class="col-sm-6 col-lg-4">
                                        <div class="d-flex align-items-start gap-3 p-3 rounded-2"
                                             style="background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1);">
                                            <div class="flex-shrink-0 mt-1">
                                                <i t-att-class="'fa fa-lg ' + scope_icons.get(benefit.benefit_scope, 'fa-star')"
                                                   style="color:#ff6b00;"/>
                                            </div>
                                            <div>
                                                <p class="mb-0 fw-semibold" style="color:#fff; font-size:0.9rem;">
                                                    <t t-esc="benefit.name"/>
                                                </p>
                                                <p class="mb-0" style="color:rgba(255,255,255,0.55); font-size:0.78rem;">
                                                    <t t-esc="scope_labels.get(benefit.benefit_scope, benefit.benefit_scope)"/>
                                                    <t t-if="benefit.benefit_type == 'discount' and benefit.discount_percent">
                                                        · <t t-esc="int(benefit.discount_percent)"/>% de descuento
                                                    </t>
                                                    <t t-elif="benefit.benefit_type in ('free', 'access')">
                                                        · Incluido
                                                    </t>
                                                </p>
                                                <t t-if="benefit.description">
                                                    <p class="mb-0 mt-1" style="color:rgba(255,255,255,0.4); font-size:0.75rem;">
                                                        <t t-esc="benefit.description"/>
                                                    </p>
                                                </t>
                                            </div>
                                        </div>
                                    </div>
                                </t>
                            </div>
                        </t>
                    </div>
                </t>

                <!-- Sin plan activo -->
                <t t-if="not best_plan and subscriptions">
                    <div class="alert mb-4 p-4 rounded-3"
                         style="background: rgba(255,107,0,0.08); border: 1px solid rgba(255,107,0,0.25); color: rgba(255,255,255,0.7);">
                        <i class="fa fa-info-circle me-2" style="color:#ff6b00;"/>
                        Tienes suscripciones, pero aún no están activas o no tienen facturas pagadas.
                        Los beneficios se activan una vez que tu suscripción esté vigente y con al menos un pago confirmado.
                    </div>
                </t>

                <!-- ============================================================
                     LISTA DE SUSCRIPCIONES
                ============================================================ -->
                <h5 class="mb-3 fw-bold" style="color:#ff6b00;">
                    <i class="fa fa-list me-2"/>
                    Mis suscripciones
                </h5>

                <t t-if="subscriptions">
                    <div class="row g-3">
                        <t t-foreach="subscriptions" t-as="sub">
                            <div class="col-md-6 col-xl-4">
                                <div class="card h-100 border-0 shadow-sm"
                                     style="background: #1a1a2e; border: 1px solid rgba(255,255,255,0.08) !important;">
                                    <div class="card-body p-4">

                                        <!-- Header de la tarjeta -->
                                        <div class="d-flex justify-content-between align-items-start mb-3">
                                            <div>
                                                <h6 class="mb-0 fw-bold text-white">
                                                    <t t-esc="sub.template_id.name or sub.name"/>
                                                </h6>
                                                <small style="color:rgba(255,255,255,0.4);">
                                                    <t t-esc="sub.code"/>
                                                </small>
                                            </div>
                                            <!-- Badge de estado -->
                                            <t t-if="sub.stage_type == 'in_progress'">
                                                <span class="badge" style="background:rgba(40,167,69,0.2); color:#28a745; border: 1px solid rgba(40,167,69,0.4);">
                                                    <i class="fa fa-circle me-1" style="font-size:0.5rem;"/>
                                                    Activa
                                                </span>
                                            </t>
                                            <t t-elif="sub.stage_type == 'pre'">
                                                <span class="badge" style="background:rgba(255,193,7,0.2); color:#ffc107; border:1px solid rgba(255,193,7,0.4);">
                                                    Por iniciar
                                                </span>
                                            </t>
                                            <t t-elif="sub.stage_type == 'post'">
                                                <span class="badge" style="background:rgba(108,117,125,0.2); color:#adb5bd; border:1px solid rgba(108,117,125,0.4);">
                                                    Cerrada
                                                </span>
                                            </t>
                                            <t t-else="">
                                                <span class="badge" style="background:rgba(255,255,255,0.05); color:rgba(255,255,255,0.4);">
                                                    Borrador
                                                </span>
                                            </t>
                                        </div>

                                        <!-- Plan del beneficio de la suscripción -->
                                        <t t-if="sub.subscription_plan_id">
                                            <div class="mb-3 d-flex align-items-center gap-2">
                                                <i class="fa fa-id-badge" style="color:#ff6b00;"/>
                                                <span style="color:rgba(255,255,255,0.7); font-size:0.85rem;">
                                                    Plan: <strong style="color:#ff6b00;"><t t-esc="sub.subscription_plan_id.name"/></strong>
                                                </span>
                                            </div>
                                        </t>

                                        <!-- Próxima factura -->
                                        <t t-if="sub.recurring_next_date">
                                            <div class="d-flex align-items-center gap-2 mb-2">
                                                <i class="fa fa-calendar-o" style="color:rgba(255,255,255,0.4);"/>
                                                <small style="color:rgba(255,255,255,0.55);">
                                                    Próxima factura:
                                                    <t t-esc="sub.recurring_next_date" t-options='{"widget": "date"}'/>
                                                </small>
                                            </div>
                                        </t>

                                        <!-- Fecha de fin -->
                                        <t t-if="sub.date">
                                            <div class="d-flex align-items-center gap-2 mb-2">
                                                <i class="fa fa-flag-o" style="color:rgba(255,255,255,0.4);"/>
                                                <small style="color:rgba(255,255,255,0.55);">
                                                    Vence:
                                                    <t t-esc="sub.date" t-options='{"widget": "date"}'/>
                                                </small>
                                            </div>
                                        </t>
                                        <t t-else="">
                                            <div class="d-flex align-items-center gap-2 mb-2">
                                                <i class="fa fa-infinity" style="color:rgba(255,255,255,0.4);"/>
                                                <small style="color:rgba(255,255,255,0.55);">Sin fecha de vencimiento</small>
                                            </div>
                                        </t>

                                        <!-- Precio recurrente -->
                                        <div class="d-flex align-items-center gap-2 mb-3">
                                            <i class="fa fa-money" style="color:rgba(255,255,255,0.4);"/>
                                            <small style="color:rgba(255,255,255,0.55);">
                                                Total:
                                                <strong style="color:#fff;">
                                                    $<t t-esc="'%.2f' % sub.amount_total"/>
                                                </strong>
                                                /
                                                <t t-esc="sub.template_id.recurring_interval"/>
                                                <t t-esc="sub.template_id.recurring_rule_type"/>
                                            </small>
                                        </div>

                                        <!-- Indicador de beneficios activos en esta suscripción -->
                                        <t t-if="sub.subscription_benefits_active">
                                            <div class="mt-3 pt-3" style="border-top: 1px solid rgba(255,255,255,0.08);">
                                                <small style="color:#ff6b00;">
                                                    <i class="fa fa-check-circle me-1"/>
                                                    Beneficios activos en esta suscripción
                                                </small>
                                            </div>
                                        </t>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </div>
                </t>

                <!-- Sin suscripciones -->
                <t t-if="not subscriptions">
                    <div class="text-center py-5">
                        <div class="mb-4">
                            <div style="width:80px; height:80px; background:rgba(255,107,0,0.1); border-radius:50%; display:flex; align-items:center; justify-content:center; margin: 0 auto;">
                                <i class="fa fa-id-card fa-2x" style="color:rgba(255,107,0,0.5);"/>
                            </div>
                        </div>
                        <h5 style="color:rgba(255,255,255,0.6);">No tienes suscripciones activas</h5>
                        <p style="color:rgba(255,255,255,0.4);">
                            Adquiere una de nuestras suscripciones para acceder a beneficios exclusivos.
                        </p>
                        <a href="/shop" class="btn mt-2"
                           style="background:#ff6b00; color:#fff; border:none;">
                            <i class="fa fa-shopping-bag me-2"/>
                            Ver planes disponibles
                        </a>
                    </div>
                </t>

            </div>
        </t>
    </template>

</odoo>
