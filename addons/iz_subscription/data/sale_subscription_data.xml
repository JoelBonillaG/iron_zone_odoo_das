<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <data noupdate="1">
        <record id="seq_id" model="ir.sequence">
            <field name="name">sale_subscription_sequencer</field>
            <field name="code">sale.subscription</field>
            <field name="prefix">SUB</field>
            <field name="padding">5</field>
        </record>

        <record id="subscription_stage_draft" model="sale.subscription.stage">
            <field name="name">Borrador</field>
            <field name="sequence">0</field>
            <field name="type">draft</field>
            <field name="description">
                Borrador, aún trabajando en los detalles.
            </field>
            <field eval="False" name="fold" />
        </record>

        <record id="subscription_stage_ready" model="sale.subscription.stage">
            <field name="name">Lista para iniciar</field>
            <field name="sequence">1</field>
            <field name="type">pre</field>
            <field name="description">
                Una suscripción está lista para empezar cuando no está marcada como en progreso, pero puede estarlo en cualquier momento. Si no hay una etapa de tipo 'Cerrada' definida, cuando una suscripción llegue a su fin de forma automática, se marcará con esta etapa.
            </field>
            <field eval="False" name="fold" />
        </record>

        <record id="subscription_stage_in_progress" model="sale.subscription.stage">
            <field name="name">Activa</field>
            <field name="sequence">2</field>
            <field name="type">in_progress</field>
            <field eval="False" name="fold" />
            <field name="description">
                Como una etapa de tipo 'En progreso', activará el proceso de facturación recurrente si corresponde. Si esta etapa es la primera - en orden de secuencia - de los tipos 'En progreso' disponibles y hay un cambio de etapa de cualquier otro tipo no 'En progreso' a este, se creará una factura automáticamente si la fecha de inicio es el día actual.
            </field>
        </record>

        <record id="subscription_stage_closed" model="sale.subscription.stage">
            <field name="name">Cerrada</field>
            <field name="sequence">3</field>
            <field name="type">post</field>
            <field eval="False" name="fold" />
            <field name="description">
                La etapa final de una suscripción. Hay dos formas de marcar una suscripción como cerrada. La más fácil es usando las capacidades de mover tarjetas kanban, presionando el botón 'Cerrar suscripción' (solo disponible si una suscripción está en progreso).
            </field>
        </record>
    </data>

    <record id="close_reason_expensive" model="sale.subscription.close.reason">
        <field name="name">La suscripción es demasiado cara</field>
    </record>

    <record id="close_reason_requirement" model="sale.subscription.close.reason">
        <field name="name">La suscripción no cumple con mis requisitos</field>
    </record>

    <record id="close_reason_ended" model="sale.subscription.close.reason">
        <field name="name">La suscripción ha terminado</field>
    </record>

    <record id="close_reason_use" model="sale.subscription.close.reason">
        <field name="name">Realmente no la uso</field>
    </record>

    <record id="close_reason_other" model="sale.subscription.close.reason">
        <field name="name">Otro</field>
    </record>
</odoo>
