{
  "name": "pruebas-iron-zone",
  "version": "1.0.0",
  "description": "Automatizacion E2E con Playwright para el Modulo 2 de Iron Zone",
  "type": "module",
  "main": "clasesGrupalesExtract.js",
  "scripts": {
    "extract": "node clasesGrupalesExtract.js",
    "register": "node clasesGrupalesRegistro.js",
    "clases:local": "node clasesGrupalesRegistroLocal.js",
    "clases:usuario-nuevo:local": "node clasesGrupalesUsuarioNuevoRegistroLocal.js",
    "clases:primer-evento-gratis:local": "node clasesGrupalesPrimerEventoGratisLocal.js",
    "clases:desplegado": "node clasesGrupalesRegistro.js",
    "suscripciones:local": "node suscripcionesRegistro.js",
    "suscripciones:usuario-nuevo:local": "node suscripcionesCompraMensualFacturaLocal.js",
    "suscripciones:compra:local": "node suscripcionesCompraMensualFacturaLocal.js",
    "suscripciones:desplegado": "node suscripcionesRegistroDesplegado.js",
    "guias:entrenador:local": "node guiaEjerciciosEntrenadorCrearLocal.js",
    "guias:local": "node guiaEjerciciosRegistro.js",
    "guias:desplegado": "node guiaEjerciciosRegistroDesplegado.js",
    "test:local": "node ejecutarPruebasLocales.js",
    "test:desplegado": "npm run clases:desplegado && npm run suscripciones:desplegado && npm run guias:desplegado"
  },
  "dependencies": {
    "@browserbasehq/stagehand": "^3.4.0",
    "dotenv": "^17.4.2",
    "playwright": "^1.60.0",
    "zod": "^4.4.3"
  }
}
